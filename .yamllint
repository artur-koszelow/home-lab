---
extends: default

rules:
  line-length: disable
  document-start: disable
  braces:
    max-spaces-inside: 1
    min-spaces-inside: 0
  comments:
    min-spaces-from-content: 1
  comments-indentation: disable
  octal-values:
    forbid-implicit-octal: true
    forbid-explicit-octal: true
  truthy:
    allowed-values:
      - 'true'
      - 'false'
      - 'yes'
      - 'no'
